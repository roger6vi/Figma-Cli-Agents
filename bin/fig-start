#!/bin/bash

# fig-start — Launch Figma CLI + AI Agent
# Connects to Figma, lets you pick an open file, then launches your AI Agent.
#
# Usage:
#   fig-start          → Yolo Mode (default) with file selector
#   fig-start --safe   → Safe Mode (plugin-based, no patching)
#   fig-start --setup  → set/change the figma-cli repo path
#   fig-start --init   → initialize current directory for figma-cli (copies AGENTS.md, creates CLAUDE.md)

CONFIG_DIR="$HOME/.figma-cli"
CONFIG_FILE="$CONFIG_DIR/config.json"
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Config helpers ──

get_daemon_token() {
    local token_file="/tmp/.figma-daemon-token"
    if [ -n "$TMPDIR" ]; then
        token_file="${TMPDIR%/}/.figma-daemon-token"
    fi
    if [ -f "$token_file" ]; then
        cat "$token_file" 2>/dev/null
    fi
}

get_config_value() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 - "$CONFIG_FILE" "$1" <<'PY' 2>/dev/null
import json, sys
path, key = sys.argv[1:3]
with open(path) as f:
    cfg = json.load(f)
value = cfg.get(key, '')
if value is not None:
    print(value)
PY
    fi
}

save_config_value() {
    mkdir -p "$CONFIG_DIR"
    python3 - "$CONFIG_FILE" "$1" "$2" <<'PY'
import json, os, sys
path, key, value = sys.argv[1:4]
cfg = {}
if os.path.exists(path):
    with open(path) as f:
        cfg = json.load(f)
cfg[key] = value
with open(path, 'w') as f:
    json.dump(cfg, f, indent=2)
PY
}

get_repo_path() {
    get_config_value "repoPath"
}

save_repo_path() {
    save_config_value "repoPath" "$1"
}

normalize_desktop_app() {
    local value="${1,,}"
    case "$value" in
        beta|"figma beta"|figma-beta)
            printf 'beta'
            ;;
        *)
            printf 'stable'
            ;;
    esac
}

get_desktop_app() {
    normalize_desktop_app "$(get_config_value "desktopApp")"
}

save_desktop_app() {
    save_config_value "desktopApp" "$(normalize_desktop_app "$1")"
}

get_desktop_app_label() {
    case "$(normalize_desktop_app "$1")" in
        beta)
            printf 'Figma Beta'
            ;;
        *)
            printf 'Figma'
            ;;
    esac
}

get_desktop_app_process_name() {
    case "$(normalize_desktop_app "$1")" in
        beta)
            printf 'Figma Beta'
            ;;
        *)
            printf 'Figma'
            ;;
    esac
}

select_desktop_app() {
    local saved_app default_choice app_choice
    saved_app="$(get_desktop_app)"
    if [ "$saved_app" = "beta" ]; then
        default_choice="2"
    else
        default_choice="1"
    fi

    echo -e "  ${BOLD}Select a Desktop App:${NC}"
    echo "    1) Figma"
    echo "    2) Figma Beta"
    echo ""
    printf "  Enter choice [1/2, default: %s]: " "$default_choice"
    read -r app_choice < /dev/tty
    echo ""

    case "$app_choice" in
        2|beta|Beta|"Figma Beta"|"figma beta")
            DESKTOP_APP="beta"
            ;;
        *)
            DESKTOP_APP="stable"
            ;;
    esac

    DESKTOP_APP_LABEL="$(get_desktop_app_label "$DESKTOP_APP")"
    DESKTOP_APP_PROCESS="$(get_desktop_app_process_name "$DESKTOP_APP")"
    save_desktop_app "$DESKTOP_APP"
    export FIGMA_DESKTOP_APP="$DESKTOP_APP"
}

# ── Arrow-key selector (same UX as fancoolo-start) ──

select_file() {
    local options=("$@")
    local count=${#options[@]}
    local selected=0

    tput civis > /dev/tty 2>/dev/null
    trap 'tput cnorm > /dev/tty 2>/dev/null' EXIT

    draw_menu() {
        if [ "$1" = "redraw" ]; then
            printf "\033[%dA" "$((count + 2))" > /dev/tty
        fi

        printf "${BOLD}Select a Figma file (↑↓ arrows, Enter to confirm):${NC}\n" > /dev/tty
        printf "\n" > /dev/tty
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$selected" ]; then
                printf "  ${GREEN}▸ %s${NC}\n" "${options[$i]}" > /dev/tty
            else
                printf "    %s\n" "${options[$i]}" > /dev/tty
            fi
        done
    }

    draw_menu "first"

    while true; do
        IFS= read -rsn1 key < /dev/tty

        case "$key" in
            $'\x1b')
                read -rsn2 seq < /dev/tty
                case "$seq" in
                    '[A')
                        ((selected--))
                        [ "$selected" -lt 0 ] && selected=$((count - 1))
                        ;;
                    '[B')
                        ((selected++))
                        [ "$selected" -ge "$count" ] && selected=0
                        ;;
                esac
                ;;
            ''|$'\n'|$'\r')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                printf '%s' "${options[$selected]}"
                return
                ;;
            'q')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                return
                ;;
        esac

        draw_menu "redraw"
    done
}

# ── AI Agent launcher ──

launch_agent() {
    echo -e "  ${BOLD}Select an AI Agent:${NC}"
    echo "    1) Claude Code (claude)"
    echo "    2) Codex (codex)"
    echo "    3) Gemini (gemini)"
    echo ""
    printf "  Enter choice [1/2/3, default: 1]: "
    read -r agent_choice < /dev/tty

    echo ""
    AGENT_CONTEXT="This is a live Figma Desktop session. The figma-cli tool is available at $REPO_PATH. Use the figma-cli commands (e.g. node $CLI <command>) to interact with Figma. Working directory: $(pwd)."
    AGENT_CONTEXT="$AGENT_CONTEXT Selected desktop app: $DESKTOP_APP_LABEL."
    if [ "$SAFE_MODE" = true ]; then
        AGENT_CONTEXT="$AGENT_CONTEXT Safe Mode is already active and the FigCli plugin is already connected unless a real figma-cli command proves otherwise."
    else
        AGENT_CONTEXT="$AGENT_CONTEXT The session was started from fig-start in Yolo Mode unless the user says otherwise."
    fi

    # Project context
    if [ -n "$FIGMA_PROJECT_DIR" ]; then
        AGENT_CONTEXT="$AGENT_CONTEXT Project directory: $FIGMA_PROJECT_DIR. Save scripts, exports, and generated files there to keep projects isolated."
        if [ -n "$SELECTED_TITLE" ]; then
            AGENT_CONTEXT="$AGENT_CONTEXT Current Figma file: $SELECTED_TITLE."
        fi
    fi

    # Skills context
    GLOBAL_SKILLS_DIR="$CONFIG_DIR/skills"
    if [ -d "$GLOBAL_SKILLS_DIR" ]; then
        SKILL_LIST=$(ls "$GLOBAL_SKILLS_DIR"/*.md "$GLOBAL_SKILLS_DIR"/*.js 2>/dev/null | xargs -I {} basename {} | tr '\n' ', ' | sed 's/,$//')
        if [ -n "$SKILL_LIST" ]; then
            AGENT_CONTEXT="$AGENT_CONTEXT Global skills available: $SKILL_LIST. Use 'node $CLI skills show <name>' to read them."
        fi
    fi
    if [ -n "$FIGMA_PROJECT_DIR" ] && [ -d "$FIGMA_PROJECT_DIR/skills" ]; then
        PROJ_SKILL_LIST=$(ls "$FIGMA_PROJECT_DIR/skills"/*.md "$FIGMA_PROJECT_DIR/skills"/*.js 2>/dev/null | xargs -I {} basename {} | tr '\n' ', ' | sed 's/,$//')
        if [ -n "$PROJ_SKILL_LIST" ]; then
            AGENT_CONTEXT="$AGENT_CONTEXT Project skills: $PROJ_SKILL_LIST."
        fi
    fi

    case "$agent_choice" in
        2|codex|Codex)
            echo -e "  ${GREEN}Launching Codex...${NC}"
            echo ""
            exec codex --dangerously-bypass-approvals-and-sandbox "$AGENT_CONTEXT"
            ;;
        3|gemini|Gemini)
            if ! command -v gemini > /dev/null 2>&1; then
                echo -e "  ${RED}Gemini is not installed or not on PATH.${NC}"
                echo "  Install it first, then run fig-start again."
                exit 1
            fi
            echo -e "  ${GREEN}Launching Gemini...${NC}"
            echo ""
            exec gemini --approval-mode yolo -i "$AGENT_CONTEXT"
            ;;
        *)
            echo -e "  ${GREEN}Launching Claude Code...${NC}"
            echo ""
            exec claude --dangerously-skip-permissions --append-system-prompt "$AGENT_CONTEXT"
            ;;
    esac
}

# ── Main ──

# Handle flags
SAFE_MODE=false
if [ "$1" = "--safe" ]; then
    SAFE_MODE=true
    shift
fi

if [ "$1" = "--setup" ]; then
    printf "${BOLD}Enter the path to your figma-cli repo:${NC} "
    read -r repo_path < /dev/tty
    repo_path="${repo_path/#\~/$HOME}"
    if [ ! -f "$repo_path/src/index.js" ]; then
        echo -e "${RED}Not a valid figma-cli repo:${NC} $repo_path"
        exit 1
    fi
    save_repo_path "$repo_path"
    echo -e "${GREEN}Saved.${NC} Run ${BOLD}fig-start${NC} to begin."
    exit 0
fi

if [ "$1" = "--init" ]; then
    # Resolve repo path first
    REPO_PATH=$(get_repo_path)
    if [ -z "$REPO_PATH" ] || [ ! -d "$REPO_PATH" ]; then
        REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
        if [ -f "$REPO_ROOT/src/index.js" ]; then
            REPO_PATH="$REPO_ROOT"
        else
            echo -e "${RED}figma-cli repo not configured.${NC} Run ${BOLD}fig-start --setup${NC} first."
            exit 1
        fi
    fi

    echo ""
    echo -e "${BOLD}  fig-start --init${NC} ${DIM}— Initialize project for Figma CLI${NC}"
    echo ""

    # Copy AGENTS.md
    if [ -f "./AGENTS.md" ]; then
        echo -e "  ${YELLOW}AGENTS.md already exists${NC} — skipped"
    else
        cp "$REPO_PATH/AGENTS.md" ./AGENTS.md
        echo -e "  ${GREEN}✓${NC} AGENTS.md copied (figma-cli command reference)"
    fi

    # Copy REFERENCE.md if it exists
    if [ -f "$REPO_PATH/REFERENCE.md" ]; then
        if [ -f "./REFERENCE.md" ]; then
            echo -e "  ${YELLOW}REFERENCE.md already exists${NC} — skipped"
        else
            cp "$REPO_PATH/REFERENCE.md" ./REFERENCE.md
            echo -e "  ${GREEN}✓${NC} REFERENCE.md copied (full command reference)"
        fi
    fi

    # Create CLAUDE.md template if it doesn't exist
    if [ -f "./CLAUDE.md" ]; then
        echo -e "  ${YELLOW}CLAUDE.md already exists${NC} — skipped"
    else
        cat > ./CLAUDE.md << 'TEMPLATE'
# Instructions

## Figma CLI

This project uses figma-cli for Figma Desktop integration.
Read `AGENTS.md` for the full command reference before interacting with Figma.

CLI location: Use `node <REPO_PATH>/src/index.js <command>` to run figma-cli commands.

## Project-specific instructions

<!-- Add your project-specific instructions, skills, and conventions below -->

TEMPLATE
        # Replace <REPO_PATH> with the actual path
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|<REPO_PATH>|$REPO_PATH|g" ./CLAUDE.md
        else
            sed -i "s|<REPO_PATH>|$REPO_PATH|g" ./CLAUDE.md
        fi
        echo -e "  ${GREEN}✓${NC} CLAUDE.md created (project template)"
    fi

    # Create README.md
    PROJ_NAME=$(basename "$(pwd)")
    if [ -f "./README.md" ]; then
        echo -e "  ${YELLOW}README.md already exists${NC} — skipped"
    else
        cat > ./README.md << READMEEOF
# $PROJ_NAME

## Description

<!-- What is this project about? -->

## Getting started

This project uses [figma-cli](https://github.com/roger6vi/Figma-Cli-Agents) for Figma Desktop integration.

\`\`\`bash
# Launch a Figma session
fig-start
\`\`\`

## Structure

<!-- Describe the project structure as it evolves -->

## Notes

<!-- Any additional notes about the project -->
READMEEOF
        echo -e "  ${GREEN}✓${NC} README.md created (project documentation)"
    fi

    # Create CHANGELOG.md
    if [ -f "./CHANGELOG.md" ]; then
        echo -e "  ${YELLOW}CHANGELOG.md already exists${NC} — skipped"
    else
        INIT_DATE=$(date +%Y-%m-%d)
        cat > ./CHANGELOG.md << CHANGELOGEOF
# Changelog

All notable changes to this project will be documented in this file.

## [$INIT_DATE] — Project initialized

- Initialized project with figma-cli (\`fig-start --init\`)
- Created base files: CLAUDE.md, AGENTS.md, REFERENCE.md
CHANGELOGEOF
        echo -e "  ${GREEN}✓${NC} CHANGELOG.md created (change log)"
    fi

    echo ""
    echo -e "  ${GREEN}Done!${NC} You can now:"
    echo -e "    - Edit ${BOLD}CLAUDE.md${NC} to add project-specific instructions"
    echo -e "    - Edit ${BOLD}README.md${NC} to document your project"
    echo -e "    - Run ${BOLD}fig-start${NC} from this directory to launch a session"
    echo ""
    exit 0
fi

# Resolve repo path
REPO_PATH=$(get_repo_path)

if [ -z "$REPO_PATH" ] || [ ! -d "$REPO_PATH" ]; then
    # Try to find it relative to this script
    REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
    if [ -f "$REPO_ROOT/src/index.js" ]; then
        REPO_PATH="$REPO_ROOT"
        save_repo_path "$REPO_PATH"
    else
        echo -e "${YELLOW}figma-cli repo not configured.${NC}"
        printf "${BOLD}Enter the path to your figma-cli repo:${NC} "
        read -r REPO_PATH < /dev/tty
        REPO_PATH="${REPO_PATH/#\~/$HOME}"
        if [ ! -f "$REPO_PATH/src/index.js" ]; then
            echo -e "${RED}Not a valid figma-cli repo:${NC} $REPO_PATH"
            exit 1
        fi
        save_repo_path "$REPO_PATH"
    fi
fi

CLI="$REPO_PATH/src/index.js"

echo ""
if [ "$SAFE_MODE" = true ]; then
    echo -e "${BOLD}  fig-start${NC} ${DIM}— Figma CLI launcher (Safe Mode)${NC}"
else
    echo -e "${BOLD}  fig-start${NC} ${DIM}— Figma CLI launcher${NC}"
fi
echo ""

select_desktop_app
echo -e "  ${GREEN}Desktop app:${NC} ${BOLD}${DESKTOP_APP_LABEL}${NC}"
echo ""

# Step 1: Check if the selected desktop app is running, start it if not
if ! pgrep -x "$DESKTOP_APP_PROCESS" > /dev/null 2>&1; then
    echo -e "  ${YELLOW}Starting ${DESKTOP_APP_LABEL}...${NC}"
    open -a "$DESKTOP_APP_LABEL"
    sleep 3
fi

# Step 2: Connect to Figma
if [ "$SAFE_MODE" = true ]; then
    # ── Safe Mode: plugin-based connection ──
    # Run connect --safe interactively so user sees plugin setup instructions
    echo -e "  ${BOLD}🔒 Safe Mode${NC} — plugin-based, no patching required"
    echo ""
    node "$CLI" connect --safe
    if [ $? -ne 0 ]; then
        echo -e "  ${RED}Connection failed.${NC}"
        exit 1
    fi
    echo ""

    # Skip file selector (Safe Mode only sees the active file via plugin)
    launch_agent
else
    # ── Yolo Mode: CDP-based connection ──
    # Check if CDP is already accessible (avoid killing/restarting Figma)
    CDP_OK=false
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:9222/json 2>/dev/null | grep -q "200"; then
        CDP_OK=true
    fi

    if [ "$CDP_OK" = true ]; then
        # Figma is already accessible — just ensure daemon is running
        DAEMON_OK=false
        DAEMON_TOKEN=$(get_daemon_token)
        if [ -n "$DAEMON_TOKEN" ]; then
            if curl -s -o /dev/null -w "%{http_code}" -H "X-Daemon-Token: $DAEMON_TOKEN" http://localhost:3456/health 2>/dev/null | grep -q "200"; then
                DAEMON_OK=true
            fi
        fi
        if [ "$DAEMON_OK" = false ]; then
            echo -e "  Starting daemon..."
            node "$CLI" daemon restart > /dev/null 2>&1
            sleep 1
        fi
        echo -e "  ${GREEN}✓ Connected${NC}"
    else
        # Not accessible — run full connect (will kill + restart Figma)
        echo -e "  Connecting to ${DESKTOP_APP_LABEL}..."
        CONNECT_OUT=$(node "$CLI" connect 2>&1)
        if [ $? -ne 0 ]; then
            echo -e "  ${RED}Connection failed:${NC}"
            echo "$CONNECT_OUT"
            echo ""
            echo -e "  ${YELLOW}Tip:${NC} Try ${BOLD}fig-start --safe${NC} if patching fails."
            exit 1
        fi
        echo -e "  ${GREEN}✓ Connected${NC}"
        # Wait for Figma to fully restore all tabs after restart
        sleep 3
    fi

    # Step 3: List open files and let user pick
    echo -e "  Loading open files..."
    FILES_JSON=$(node "$CLI" files 2>/dev/null)

    if [ -z "$FILES_JSON" ] || echo "$FILES_JSON" | grep -q '"error"'; then
        echo -e "  ${RED}Could not list files.${NC} Is ${DESKTOP_APP_LABEL} open with a file?"
        exit 1
    fi

    # Parse file titles
    FILE_TITLES=()
    while IFS= read -r title; do
        FILE_TITLES+=("$title")
    done < <(echo "$FILES_JSON" | python3 -c "
import json, sys
files = json.load(sys.stdin)
for f in files:
    t = f.get('title', 'Untitled')
    # Clean up Figma title format (remove ' – Figma' suffix)
    t = t.replace(' – Figma', '').replace(' - Figma', '')
    print(t)
" 2>/dev/null)

    if [ ${#FILE_TITLES[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}No Figma files detected.${NC} Open a file in ${DESKTOP_APP_LABEL} first."
        echo ""
        echo -e "  Launching AI Agent anyway..."
        echo ""
        launch_agent
    fi

    SELECTED_TITLE=""

    echo ""
    SELECTED_TITLE=$(select_file "${FILE_TITLES[@]}")
    if [ -z "$SELECTED_TITLE" ]; then
        echo "  Cancelled."
        exit 0
    fi

    echo -e "  ${GREEN}✓ File: ${BOLD}${SELECTED_TITLE}${NC}"

    # Step 3b: Resolve project directory for the selected file
    SELECTED_FILE_KEY=$(echo "$FILES_JSON" | python3 -c "
import json, sys, re
files = json.load(sys.stdin)
title = sys.argv[1]
for f in files:
    t = f.get('title', 'Untitled').replace(' – Figma', '').replace(' - Figma', '')
    if t == title:
        url = f.get('url', '')
        m = re.search(r'/(design|board)/([^/]+)', url)
        print(m.group(2) if m else '')
        break
" "$SELECTED_TITLE" 2>/dev/null)

    SELECTED_FILE_URL=$(echo "$FILES_JSON" | python3 -c "
import json, sys
files = json.load(sys.stdin)
title = sys.argv[1]
for f in files:
    t = f.get('title', 'Untitled').replace(' – Figma', '').replace(' - Figma', '')
    if t == title:
        print(f.get('url', ''))
        break
" "$SELECTED_TITLE" 2>/dev/null)

    RESOLVE_ARGS="--title \"$SELECTED_TITLE\""
    [ -n "$SELECTED_FILE_KEY" ] && RESOLVE_ARGS="$RESOLVE_ARGS --file-key \"$SELECTED_FILE_KEY\""
    [ -n "$SELECTED_FILE_URL" ] && RESOLVE_ARGS="$RESOLVE_ARGS --url \"$SELECTED_FILE_URL\""

    PROJECT_DIR=$(eval node "$CLI" project resolve $RESOLVE_ARGS 2>/dev/null)

    if [ -n "$PROJECT_DIR" ]; then
        export FIGMA_PROJECT_DIR="$PROJECT_DIR"
        echo -e "  ${GREEN}✓ Project:${NC} ${DIM}$PROJECT_DIR${NC}"
    fi

    echo ""

    # Step 4: Launch AI Agent from repo directory
    launch_agent
fi
